# Environment
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3001

# Database
DATABASE_URL=postgresql://klaimswift:klaimswift_dev@localhost:5432/klaimswift?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# S3 (MinIO for development)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=klaimswift-documents
S3_REGION=us-east-1

# M-Pesa (Sandbox)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Logging
LOG_LEVEL=debug
